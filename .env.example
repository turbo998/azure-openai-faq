# ===== OpenAI (官方) =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Azure OpenAI =====
# 形如 https://my-aoai.openai.azure.com（不要带尾部斜杠）
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
# v1 API 推荐使用 preview；旧版 deployments 路径请使用 GA 版本，例如 2024-10-21
AZURE_OPENAI_API_VERSION=preview

# 部署名（不是模型名！在 Azure AI Foundry / 门户 "Deployments" 处自定义）
AZURE_OPENAI_GPT55_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2

# ===== AAD / Managed Identity（可选，推荐用于生产）=====
# 留空走 DefaultAzureCredential
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ===== 可选：Image b64 -> URL workaround（Azure Blob Storage SAS）=====
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=images
AZURE_STORAGE_CONNECTION_STRING=
